<odoo>
    <data>
        <!-- REQUEST SECTION -->
        <record id="po_request_view_list" model="ir.ui.view">
            <field name="name">po.request.view.list</field>
            <field name="model">po_request</field>
            <field name="arch" type="xml">
                <list string = "Channel">
                    <control>
                        <create name="custom_line" string="Create new request.."/>
                    </control>
                    <field name="name" width = "25%"/>
                    <field name="document_no" width = "25%"/>
                    <field name="revision_no" width = "25%"/>
                    <field name="valid_date" width = "25%"/>
                </list>
            </field>
        </record>
        
        <record id="po_request_item_view_list" model="ir.ui.view">
            <field name="name">po.request.item.view.list</field>
            <field name="model">po_request_item</field>
            <field name="arch" type="xml">
                <list string = "Channel" editable = "bottom">
                    <control>
                        <create name="custom_line" string="Add item to requests list.."/>
                    </control>
                    <field name="name" width = "20%"/>
                    <field name="description" width = "20%"/>
                    <field name="department" width = "20%"/>
                    <field name="quantity" width = "20%"/>
                    <field name="estimated_price" width = "20%"/>
                </list>
            </field>
        </record>

        <record id="po_request_form" model="ir.ui.view">
            <field name="name">po.request.form</field>
            <field name="model">po_request</field>
            <field name="arch" type="xml">
                <form string="Request Form">
                    <header class = "req-header-pad">
                        <button class = "po-header-button btn-primary fa fa-paper-plane" type = "object" string = "Create Request" name ="do_nothing"/>
                    </header>
                    <group class = "req-format-grid">

                        <sheet class = "req-format-grid-child">
                            <group class = "req-grid-row req-format-grid-child-group">
                                <div class = "expand"><h3>Document Info</h3></div>
                                <group class = "req-aff-display">
                                    <field name="name"/>
                                    <field name="document_no"/>
                                    <field name="revision_no"/>
                                    <field name="valid_date"/>
                                </group>
                            </group>
                        </sheet>

                        <sheet class = "req-format-grid-child">
                            <group class = "req-grid-row req-format-grid-child-group">
                                <div class = "expand"><h3>Affiliated Groups</h3></div>
                                <group class = "req-aff-display">
                                    <field name="affiliated_one"/>
                                    <field name="affiliated_two"/>
                                </group>
                            </group>
                        </sheet>
                        
                        <sheet>
                            <notebook>
                                <page string="Item Requests">
                                    <field name="request_items"/>
                                </page>
                            </notebook>
                        </sheet>
                        
                    </group>

                </form>
            </field>
        </record>

        <!-- END OF REQUEST -->
        
        <!-- PURCHASE ORDER CONTENT VIEW LIST, EDITABLE BOTTOM -->
        <record id="po_content_view_list" model="ir.ui.view">
            <field name="name">po.content.view.list</field>
            <field name="model">purchase_order_content</field>
            <field name="arch" type="xml">
                <list class = "poc_list" string = "Channel" editable="bottom" limit="10">
                    <control>
                        <create name="custom_line" string="Create new entry.."/>
                    </control>
                    
                    <field name="item_id" width = "7%"/> <!--5% -->
                    <field name="item_name" width = "10%"/> <!--15%-->
                    <field name="free_text" width = "10%"/> <!-- 25%-->
                    <field name="quantity_consider" width = "5%"/> <!-- 27.5-->  
                    <field name="quantity_packaging" width = "7%"/> <!-- 32.5-->
                    <field name="packaging_uom" width = "3.5%"/> <!-- 36 -->
                    <field name="quantity" width = "2.5%"/> <!--38.5-->
                    <field name="uom" width = "2.5%"/> <!-- 41.5 -->
                    <field name="price" width = "5.5%"/> <!-- 47.5-->
                    <field name="discount_percentage" width = "2.5%"/> <!-- 50%-->
                    <field name="total" width = "5.5%"/> <!--55.5%-->
                    <field name="tax_code" width = "2.5%"/> <!-- 58% -->
                    <field name="rate" width = "2.5%"/>  <!-- 61% -->
                    <field name="total_after_discount" width = "5.5%"/> <!--66.5-->
                    <field name="gross_after_discount" width = "5.5%"/> <!--72%-->
                    <field name="taxline" width = "5.5%"/> <!-- 77.5%-->
                    <!-- <field name="warehouse"/> -->
                    <field name="pi_number" width = "5.5%"/> <!--83%-->
                    <field name="slaughterhouse" width = "5.5%"/> <!-- 88.5-->
                    <field name="quantity_real" width = "5.5%"/> <!-- 94%-->
                    <!-- <field name="linestat"/> -->
                    <!-- <field name="DocEntrySomething"/> -->
                </list>
            </field>
        </record>
        
        <!-- PO FREIGHT LIST VIEW, EDITABLE BOTTOM -->
        <record id="po_freight_view_list" model="ir.ui.view">
            <field name="name">po.freight.view.list</field>
            <field name="model">purchase_order_freight</field>
            <field name="arch" type="xml">
                <list string = "Channel" editable="bottom">
                    <control>
                        <create name="custom_line" string="Create new entry.."/>
                    </control>
                    <field name="express_id"/>
                    <field name="expense_name"/>
                    <field name="remarks"/>
                    <field name="tax_code"/>
                    <field name="gross_amount"/>
                </list>
            </field>
        </record>
        
        <!-- PO VIEWLIST, yang muncul di halaman utama -->
        <record id="po_attachment_list" model="ir.ui.view">
            <field name="name">po.view.list</field>
            <field name="model">purchase_order</field>
            <field name="arch" type="xml">
                <list string = "Channel">
                    <field name="po_number" width = "50px"/>
                    <field name="name" width = "50px"/>
                    <field name="due_date" width = "50px"/>
                    <field name="total_amount" width = "50px"/>
                    <field name="payment_terms" width = "50px"/>
                    <field name="status" width = "50px"/>
                </list>
            </field>
        </record>
        
        <!-- Attachments List table view. -->
        <record id="po_view_list" model="ir.ui.view">
            <field name="name">po.attachment.list</field>
            <field name="model">ir.attachment</field>
            <field name="inherit_id" ref="base.view_attachment_tree"/>
            <field name="arch" type="xml">                         
                <xpath expr="//list" position="inside">
                    <control>
                        <create name="custom_line" string="Add an attachment"/>
                    </control>
                </xpath>
         
                <xpath expr="//field[@name='res_model']" position="attributes">
                    <attribute name="column_invisible">True</attribute>
                </xpath>
                <xpath expr="//field[@name='res_id']" position="attributes">
                    <attribute name="column_invisible">True</attribute>
                </xpath>
                <xpath expr="//field[@name='res_field']" position="attributes">
                    <attribute name="column_invisible">True</attribute>
                </xpath>
            </field>
        </record>
        
        <!-- Purchase Order Form -->
        <record id="po_form" model="ir.ui.view">
            <field name="name">po.form</field>
            <field name="model">purchase_order</field>
            <field name="arch" type="xml">
                <form string="Halaman Estate">
                    <header>
                        <button class = "po-header-button btn-primary fa fa-paper-plane" type = "object" string = "Send" name ="count_total"/>
                        <button class = "po-header-button btn-primary fa fa-refresh" type = "object" string = "Update" name ="count_total"/>
                        <!-- <button type = "object" string = "OLD PO" name ="create_purchase_order_report"/>
                        <button type = "object" string = "OLD RECEIVING" name ="create_receiving_report"/> -->
                        <button  class = "po-header-button btn-primary fa fa-print" type = "object" string = "Create PO Report" name ="template_create_purchase_report"/>
                        <button class = "po-header-button btn-primary fa fa-print" type = "object" string = "Create Receiving Report" name ="template_create_receiving_report"/>
                    </header>
                    <sheet>
                        <group class ="format-grid">
                            <group class = "format-bg">
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">PO Number</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="po_number" placeholder = "e.g. PO2244001"/>
                                </div>
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Vendor</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="vendor"/>
                                </div>
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Name</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="name" placeholder = "e.g. John Doe Johnson"/>
                                </div>
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Contact Person</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="contact_person"/>
                                </div>
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Vendor Ref. No.</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="vendor_ref_no" placeholder = "e.g. 112200334"/>
                                </div>
                            </group>
                            <group class = "format-bg">
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">STA Date</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="sta_date"/>
                                </div>
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Posting Date</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="posting_date"/>
                                </div>
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Payment Date</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="payment_date"/>
                                </div>
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Due Date</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="due_date"/>
                                </div>
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Rate</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="rate"/>
                                </div>
                            </group>
                            <group class = "format-bg">
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Discount (%)</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="discount_percentage"/>
                                </div>
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Tax</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="tax"/>
                                </div>

                                <!-- TOTAL BEFORE DISCOUNT CALCULATIONS -->
                                
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override readonly">Total Before Disc.</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box readonly-bg text-center input-text-center" name="total_before_disc"/>
                                </div>

                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override readonly">Discount Amnt.</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box readonly-bg text-center" name="discount_amount"/>
                                </div>

                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override readonly">Total</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box readonly-bg text-center" name="total_amount"/>
                                </div>

                                <!-- END TOTAL BEFORE DISCOUNT CALCULATION -->
                            </group>
                            <group class = "format-bg-with-remarks">
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Payment Term</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="payment_terms"/>
                                </div>
                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Status</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "input-box" name="status"/>
                                </div>

                                <span class = "o_form_label o_td_label">
                                    <div class = "o_form_label_override">Remarks</div>
                                </span>
                                <div class = "input-box-parent-div">
                                    <field class = "remarks-input-box" name="remarks" placeholder = "Write relevant remarks"/>
                                </div>
                                
                            </group>
                        </group>
                        <notebook>
                            <page string="Content">
                                <field name="purchase_contents"/>
                            </page>
                            <page string="Logistics">
                                <group>
                                    <field name="ship_to" placeholder = "Select location to ship to.."/>
                                    <field name="pay_to" placeholder = "Select payment recipient.."/>
                                </group>
                            </page>
                            <page string="Freight">
                                <field name="purchase_freights"/>
                            </page>
                            <page string="Attachment">
                                <field name="att_attachment"/>
                            </page>
                            <page string = "Additional">
                                <group class = "format-grid-additional">
                                    <group class = "format-bg-add">

                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">Vessel / Flight</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_vessel_flight" placeholder="---"/>
                                        </div>
                                        
                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">Container</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_container" placeholder="---"/>
                                        </div>
                                        
                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">AWB No/ BI No</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_awb" placeholder="---"/>
                                        </div>
                                        
                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">Pesawat</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_pesawat" placeholder="---"/>
                                        </div>
                                        <div>Kurang Disini</div>
                                    </group>
                                    <group class = "format-bg-add">

                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">Vendor DO No</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_vendor_DO_no" placeholder="---"/>
                                        </div>
                                        
                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">No dan tanggal PIB</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_no_tanggal_PIB" placeholder="---"/>
                                        </div>
                                        
                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">PIB Nomor Pesan</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_PIB_pesan" placeholder="---"/>
                                        </div>
                                        
                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">Bank Name</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_bank_name" placeholder="---"/>
                                        </div>
                                        
                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">PPH</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_pph" placeholder="---"/>
                                        </div>
                                        
                                    </group>
                                    <group class = "format-bg-add">

                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">Tgl BBCP</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_tgl_bbpcp" placeholder="---"/>
                                        </div>
                                        
                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">Total CF</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_total_cf" placeholder="---"/>
                                        </div>
                                        
                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">NDPBM</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_NDPBM" placeholder="---"/>
                                        </div>
                                        
                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">PI Date</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_pi_date" placeholder="---"/>
                                        </div>

                                    </group>
                                    <group class = "format-bg">
                                        <span class = "o_form_label o_td_label">
                                            <div class = "o_form_label_override">Tgl Invoice</div>
                                        </span>
                                        <div class = "format-box-parent-div">
                                            <field class = "input-box" name="ad_tgl_invoice" placeholder="---"/>
                                        </div>

                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        

        <!-- MAIN VIEWS -->

        <record id="po_requests_list" model ="ir.actions.act_window">
            <field name = "name">Form Permintaan List</field>
            <field name = "res_model">po_request</field>
            <field name="view_mode">list,form</field>
        </record>
        
        <!-- Tampilan Form Secara Individu -->
        <record id="po_form_action" model="ir.actions.act_window">
            <field name="name">Purchase Order Form</field>
            <field name="res_model">purchase_order</field>
            <field name="view_mode">form</field>
        </record>
        
        <!-- Tampilan form itu tersendiri -->
        <record id="po_list_action" model="ir.actions.act_window">
            <field name="name">Purchase Order List</field>
            <field name="res_model">purchase_order</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>