<odoo>
    <template id="report_purchase_order_template">
        <t t-foreach="docs" t-as="po">
            <t t-call="web.html_container">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <!--  This will divide the row into two partitions -->
                        <!-- Company, Recipient/Vendor name | No. and Date: -->
                        <div style="background-color : #e0e0e0;
                                    display:grid;
                                    grid-template-columns: 1fr 1fr;
                                    height: 200px;"> 
                            <div style="background-color: rgb(189, 153, 151);;
                                        display: grid;
                                        grid-template-rows: 60% 40%;
                                        padding: 10px;">
                                <div>
                                    <div style = "font-size : 24px;
                                                  font-weight : bold;">
                                        PT. INDOGUNA UTAMA
                                    </div>
                                    <div>
                                        Jl. Taruna No. 8 Pondok Bambu Jakarta Timur - Indonesia
                                    </div>
                                </div>
                                <div class = "header-subheader">
                                    <div class = "report-below-header">
                                        <span style = "font-weight : bold;
                                                       font-size: 18px" t-field="po.name"/>
                                    </div>
                                    <div>
                                        Kawasan GHC Blok CC no. 5 Kota Deltamas Kec. CIkarang Pusat, Jawa Barat.
                                    </div>
                                </div>
                            </div>
                            <div style="background-color : rgb(184, 184, 184);
                                        display: grid;
                                        grid-template-rows: 1fr 1fr;
                                        padding: 10px;
                                        justify-content: center;">
                                <div style= "display: grid;
                                             grid-template-columns: 1fr 1fr 1fr;">
                                    <div>No</div>
                                    <div>:</div>
                                    <span t-field="po.po_number"/>
                                    <div>Date</div>
                                    <div>:</div>
                                    <span t-field="po.posting_date"/>
                                </div>
                            </div>
                        </div>
                        
                        <div style="font-weight : bold;
                                    display: grid;
                                    grid-template-rows: 50px;
                                    justify-content: center;
                                    align-items: center;
                                    font-size: 18px;">
                            PURCHASE ORDER
                        </div>

                        <table style="border-style : solid;
                                      border-width: 2px;" class="table">
                            <thead>
                                <tr>
                                    <th><strong>Description</strong></th>
                                    <th><strong>Supplier UOM</strong></th>
                                    <th><strong>Our UOM</strong></th>
                                    <th><strong>Unit Price</strong></th>
                                    <th><strong>Total</strong></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="po_order" t-value="po.mapped('purchase_contents')"/>
                                <tr t-foreach="po_order" t-as="po_order">
                                    <td style="width: 50px;">
                                        <span t-field="po_order.item_id"/>
                                        --
                                        <span t-field="po_order.item_name"/>
                                    </td>
                                    <td style="width: 15px;">
                                        <span t-field="po_order.packaging_ucm"/>
                                    </td>
                                    <td style="width: 15px;">
                                        <span t-field="po_order.packaging_ucm"/>
                                    </td>
                                    <td style="width: 15px;">
                                        <span t-field="po_order.price"/>
                                    </td>
                                    <td style="width: 15px;">
                                        <span t-field="po_order.total"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <div>
                            <div>
                                Sub Total
                                <span t-field="po.total_before_disc"/>
                            </div>
                            <div>
                                Discount
                                <span t-field="po.discounted_value"/>
                            </div>
                            <div>
                                Total
                                <span t-field="po.discount_amount"/>
                            </div>
                            <div>
                                Tax
                                <span t-field="po.taxed_amount"/>
                            </div>
                            <div>
                                By Shipment
                                <span t-field="po.tax"/>
                            </div>
                            <div>
                                Inland Fuel
                                <span t-field="po.tax"/>
                            </div>
                            <div>
                                Sticker Free
                                <span t-field="po.tax"/>
                            </div>
                            <div>
                                Ocean Fuel
                                <span t-field="po.tax"/>
                            </div>
                            <div>
                                GST
                                <span t-field="po.tax"/>
                            </div>
                            <div>
                                Grand Total
                                <span t-field="po.total_amount"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>